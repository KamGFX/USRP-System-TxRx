%% 1. Cargar imagen
img = imread('Mi_valen.jpeg');

% Asegurar tamaño mayor a 740x492


%% 2. Procesamiento de imagen a color
img_d = double(img);


% Saturación
img_d(img_d > 255) = 255;

img_proc = uint8(img_d);

%% 3. Empaquetar para From Workspace (Simulink)
img_ws.time = 0;                        % tiempo único
img_ws.signals.values = img_proc;      % imagen procesada
img_ws.signals.dimensions = size(img_proc);

%% 4. (Opcional) Visualización en MATLAB
figure
imshow(img_proc)
title('Imagen procesada enviada a Simulink')

img_sim = out.img_out_ws.Data;

whos img_sim        % Verifica tipo y tamaño
